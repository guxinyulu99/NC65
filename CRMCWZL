select * from 
(
select
'原合并报表' as 报表类型,
报表体系编码,
报表体系名称,
报表体系编码||'—'||报表体系名称  编码名称,
年度,
会计期间,
月份,
指标名称,
日期,
期末余额,
显示顺序,
表顺序

FROM 
(
 select
  zcfz.RPT_TYPE as 报表类型
  ,zcfz.ORGCODE as 报表体系编码
  ,zcfz.ORGNAME as 报表体系名称
  ,to_char(zcfz.CYEAR) as 年度
  ,zcfz.CPERIOD as 会计期间
  ,to_char(zcfz.PERIOD_DATE,'yyyy-mm') 月份
  ,zcfz.RPT_PROJ as 指标名称
  ,zcfz.PERIOD_DATE as 日期
  ,zcfz.BALANCE_MNY as 期末余额
  ,zcfz.DISP_SEQ as 显示顺序 
  ,'1-资产负债表' AS 表顺序
from DW_ZCFZ_DT zcfz
where zcfz.Rpt_Type = '合并99' and RPT_PROJ not in ('期初差异','期末差异','期初负债率','期末负债率')
and to_char(zcfz.PERIOD_DATE,'yyyy-mm')= '${yperiod}'

union

 select distinct
  zcfz.RPT_TYPE as 报表类型
  ,zcfz.ORGCODE as 报表体系编码
  ,zcfz.ORGNAME as 报表体系名称
  ,substr('${yperiod}',1,4) as 年度
  ,0 as 会计期间
  ,'${yperiod}' 月份
  ,zcfz.RPT_PROJ as 指标名称
  ,sysdate as 日期
  ,0 as 期末余额
  ,zcfz.DISP_SEQ as 显示顺序 
  ,'1-资产负债表' AS 表顺序
from DW_ZCFZ_DT zcfz
where zcfz.Rpt_Type = '合并99' and RPT_PROJ not in ('期初差异','期末差异','期初负债率','期末负债率')

union


SELECT 
lrb. RPT_TYPE 
,lrb. ORGCODE 
,lrb. ORGNAME 
,to_char(lrb. CYEAR) 
,lrb. CPERIOD 
,to_char(lrb.PERIOD_DATE,'yyyy-mm') 
