FROM DW_LRB_DT lrb
where lrb.Rpt_Type = '合并99'  and RPT_PROJ not in ('营业收入','营业成本','综合毛利率','成本费用占营业收入的比重','成本费用利润率','期间费用率','销售费用率','管理费用率','研发费用率','财务费用率','所得税率','销售净利率')
and to_char(lrb.PERIOD_DATE,'yyyy-mm')= '${yperiod}'  

